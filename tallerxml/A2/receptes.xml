<?xml version="1.0" encoding="UTF-8"?>
<receptari>
    <recepta nom="Pastís de xocolata">
        <ingredients>
            <ingredient quantitat="6">rovells d'ou</ingredient>
            <ingredient quantitat="6">clares</ingredient>
            <ingredient quantitat="150" unitat="g">sucre</ingredient>
            <ingredient quantitat="200" unitat="g">xocolata negra de cobertura</ingredient>
            <ingredient quantitat="50" unitat="g">mantega</ingredient>
            <ingredient>farina</ingredient>
            <guarnicio>
                <item>nata muntada</item>
                <item>cacau en pols</item>
            </guarnicio>
        </ingredients>
        <preparacio>
            <pas>Barregeu els rovells d'ou amb el sucre en un bol.</pas>
            <pas>Foneu la cobertura de xocolata al bany maria. Afegiu-hi la mantega.</pas>
            <pas>Munteu les clares a punt de neu.</pas>
            <pas>Barregeu la xocolata amb els rovells i incorporeu les clares muntades.</pas>
            <pas temperatura="180" unitat="graus" temps="30" unitat_temps="minuts">Coure al forn.</pas>
            <pas>Deixeu refredar, desemmotlleu i decoreu amb nata i cacau.</pas>
        </preparacio>
        <notes>Recepta del programa de TV3 Cuines, del restaurant Les Petxines.</notes>
        <autors>
            <autor>Bàrbara Casanovas</autor>
            <autor>Adrià Ruscalleda</autor>
        </autors>
        <etiquetes>
            <etiqueta>Postre</etiqueta>
            <etiqueta>Dolços</etiqueta>
            <etiqueta>Forn</etiqueta>
            <etiqueta>Aniversari</etiqueta>
            <etiqueta>Fàcil</etiqueta>
            <etiqueta>Econòmic</etiqueta>
        </etiquetes>
    </recepta>

    <recepta nom="Volcà de xocolata">
        <metadades preparacio_minuts="30" cost_euros="15" calories="220" />
        <ingredients>
            <ingredient quantitat="4">ous</ingredient>
            <ingredient quantitat="4">rovells</ingredient>
            <ingredient quantitat="80" unitat="g">sucre</ingredient>
            <ingredient quantitat="220" unitat="g">mantega</ingredient>
            <ingredient quantitat="220" unitat="g">xocolata</ingredient>
            <ingredient quantitat="60" unitat="g">farina</ingredient>
        </ingredients>
        <preparacio>
            <pas>Foneu al bany maria la xocolata i la mantega.</pas>
            <pas>Munteu les clares afegint-hi el sucre.</pas>
            <pas>Barregeu la meitat de les clares amb la xocolata, incorporeu la farina i la resta de clares.</pas>
            <pas>Pinteu motlles individuals, farciu fins a la meitat, poseu un dau de xocolata i acabeu de omplir.</pas>
            <pas temperatura="220" unitat="graus" temps="10" unitat_temps="minuts">Coer al forn (només baix).</pas>
            <pas>Servir calent amb sucre llustre, salsa o gelat.</pas>
        </preparacio>
        <autors>
            <autor>anna</autor>
        </autors>
        <etiquetes>
            <etiqueta>Postre</etiqueta>
            <etiqueta>Dolços</etiqueta>
            <etiqueta>Festa</etiqueta>
            <etiqueta>Fàcil</etiqueta>
            <etiqueta>Econòmic</etiqueta>
            <etiqueta>Catalana</etiqueta>
        </etiquetes>
    </recepta>

    <recepta nom="Pastís de formatge">
        <ingredients>
            <ingredient quantitat="2" unitat="terrines">formatge Philadelphia (200-300gr.)</ingredient>
            <ingredient quantitat="3">ous</ingredient>
            <ingredient quantitat="3">iogurts naturals</ingredient>
            <ingredient quantitat="3" unitat="cullerades grans">farina</ingredient>
            <ingredient quantitat_min="10" quantitat_max="12" unitat="culleretes petites">sucre</ingredient>
            <ingredient>Un parell de galetes Maria o Chiquilín</ingredient>
        </ingredients>
        <preparacio>
            <pas temperatura="200" unitat="graus">Escalfar el forn.</pas>
            <pas>Barrejar formatge, ous i iogurts fins a tenir una pasta homogènia.</pas>
            <pas>Afegir farina i sucre sense deixar grumolls.</pas>
            <pas>Triturar galetes per a la base del motlle untat amb mantega.</pas>
            <pas temperatura="170" unitat="graus" temps_min="20" temps_max="30" unitat_temps="minuts">Coure al forn.</pas>
            <pas>Opcional: afegir capa de melmelada de maduixa o gerds.</pas>
        </preparacio>
        <notes>Una delícia pels més formatgers!!!</notes>
        <autors>
            <autor>eulalia</autor>
        </autors>
        <etiquetes>
            <etiqueta>Postre</etiqueta>
        </etiquetes>
    </recepta>
</receptari>